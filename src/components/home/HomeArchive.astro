---
import HomeSection from './HomeSection.astro';
import { HOME_ARCHIVE_INTRO, HOME_SECTIONS } from '../../lib/homeSections';
import './HomeArchive.scss';

const sections = HOME_SECTIONS.filter((section) => section.enabled !== false).sort(
	(a, b) => a.order - b.order,
);
---

<section class="home-archive" aria-labelledby="home-archive-title" data-home-archive>
	<div class="home-archive__inner">
		<div class="home-archive__intro" data-home-reveal>
			{HOME_ARCHIVE_INTRO.eyebrow && <p class="home-archive__eyebrow">{HOME_ARCHIVE_INTRO.eyebrow}</p>}
			<h2 id="home-archive-title">{HOME_ARCHIVE_INTRO.title}</h2>
		</div>

		<div class="home-archive__sections">
			{sections.map((section, index) => <HomeSection section={section} index={index + 1} />)}
		</div>
	</div>
</section>
