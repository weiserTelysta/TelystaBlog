---
import { BLOG_PAGE_CONFIG } from '../../lib/blogPageConfig';

type Props = {
	years: number[];
};

const { years } = Astro.props;
const { yearJump } = BLOG_PAGE_CONFIG;
---

{
	years.length > 0 && (
		<nav class="blog-year-jump" aria-label={yearJump.ariaLabel}>
			<p>{yearJump.title}</p>
			<div>
				{years.map((year) => (
					<a href={`#year-${year}`}>{year}</a>
				))}
			</div>
		</nav>
	)
}

<style lang="scss">
	.blog-year-jump {
		display: grid;
		gap: 12px;
		margin-top: clamp(30px, 5vw, 48px);
		padding-top: 22px;
		border-top: 1px solid rgba(255, 255, 255, 0.055);
	}

	.blog-year-jump p {
		margin: 0;
		color: rgba(156, 199, 232, 0.48);
		font-family: var(--font-display);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.blog-year-jump div {
		display: flex;
		flex-wrap: wrap;
		gap: 9px;
	}

	.blog-year-jump a {
		padding: 4px 0;
		color: rgba(190, 199, 214, 0.5);
		font-family: var(--font-display);
		font-size: 0.86rem;
		letter-spacing: 0.05em;
		transition: color 0.2s ease;
	}

	.blog-year-jump a:hover {
		color: rgba(237, 243, 251, 0.84);
	}
</style>
