---
import CategoryAccordion from './CategoryAccordion';
import { BLOG_PAGE_CONFIG } from '../../lib/blogPageConfig';
import { type BlogCategoryId, type CategoryPostCount } from '../../lib/blogCategories';
import { BLOG_CATEGORY_VISUALS } from '../../lib/blogCategoryVisuals';

type Props = {
	selectedCategoryId?: BlogCategoryId;
	postCounts: CategoryPostCount;
	totalCount: number;
};

const { selectedCategoryId, postCounts, totalCount } = Astro.props;
const { categoryIndex } = BLOG_PAGE_CONFIG;
---

<section class="blog-category-index" aria-label={categoryIndex.ariaLabel}>
	<CategoryAccordion
		client:load
		visuals={BLOG_CATEGORY_VISUALS}
		selectedCategoryId={selectedCategoryId}
		postCounts={postCounts}
		totalCount={totalCount}
	/>
</section>

<style lang="scss">
	.blog-category-index {
		display: grid;
		gap: 12px;
	}
</style>
